# ─── Rise & Shine Itinerary — live data credentials ───
# Copy to .env.local for local dev, or set in Vercel → Project → Settings → Environment Variables.
# Every provider has a labelled MOCK FALLBACK: the app runs and renders without keys,
# clearly marking sample data. Add a key → that provider goes live automatically.

# Amadeus Self-Service (flights + hotels) — https://developers.amadeus.com  (free tier)
# "test" env is free; switch AMADEUS_ENV=production once you have a production app.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test

# Google Places (restaurants + monuments/attractions, photos, hours, veg filter)
# https://console.cloud.google.com → enable "Places API (New)". Needs a billing card.
GOOGLE_PLACES_API_KEY=

# Itinerary brain — Claude. Use EITHER the Vercel AI Gateway OR a direct Anthropic key.
# Gateway (recommended on Vercel): https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=
# …or direct Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=
# Model id (gateway form provider/model, or anthropic id when using ANTHROPIC_API_KEY)
ITINERARY_MODEL=anthropic/claude-sonnet-4-6

# Reddit traveller intel — https://www.reddit.com/prefs/apps (create a "script" app, free)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=riseandshine-itinerary/2.0 (by /u/yourname)

# FX (USD→INR) used for INR display when no live FX source. Indicative.
USD_INR_RATE=85.5
